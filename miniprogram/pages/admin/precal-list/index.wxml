<view class="container">
  <view class="card">
    <view class="row">
      <view>
        <view class="card-title">Admin - Pre-cal 管理</view>
        <view class="muted">查看全部记录、维护 SAP、解锁或取消 Pre-cal。</view>
      </view>
      <button class="btn-secondary" size="mini" bindtap="goParams">参数维护</button>
    </view>
  </view>
  <input class="input search" placeholder="搜索客户 / Sales / SAP号" value="{{keyword}}" bindinput="onSearchInput" />
  <view class="filter-row">
    <view wx:for="{{statusOptions}}" wx:key="value" class="filter {{filterStatus == item.value ? 'active' : ''}}" data-status="{{item.value}}" bindtap="switchStatus">{{item.label}}</view>
  </view>
  <view wx:if="{{records.length == 0}}" class="empty">暂无记录</view>
  <view wx:for="{{records}}" wx:key="_id" class="card" bindtap="goDetail" data-id="{{item._id}}">
    <view class="row">
      <view>
        <view class="metric-value">{{item.customerNameText}}</view>
        <view class="muted">{{item.service}} ｜ Sales：{{item.salesOwnerNameText}}</view>
      </view>
      <view class="tag">{{item.statusLabel}}</view>
    </view>
    <view class="metric-line"><text>总订单金额</text><text>{{item.totalOrderValueText}}</text></view>
    <view class="metric-line"><text>SAP号</text><text>{{item.sapTextDisplay}}</text></view>
    <view wx:if="{{item.hasActions}}" class="actions" catchtap="noop">
      <button wx:if="{{item.canMaintainSap}}" class="btn-secondary" size="mini" data-id="{{item._id}}" catchtap="goBindSap">维护 SAP</button>
      <button wx:if="{{item.canUnlock}}" class="btn-secondary" size="mini" data-id="{{item._id}}" catchtap="unlock">解锁</button>
      <button wx:if="{{item.canCancel}}" class="btn-danger" size="mini" data-id="{{item._id}}" catchtap="cancel">取消</button>
    </view>
  </view>
</view>
