<view class="container">
  <view wx:if="{{!record._id}}" class="empty">加载中...</view>

  <block wx:else>
    <view class="card">
      <view class="card-title">{{record.customerName}}</view>
      <view class="muted">{{record.precalNo}} ｜ {{record.service}} ｜ {{record.status}}</view>
      <view class="metric-line"><text>Sales</text><text>{{record.salesOwnerNameText}}</text></view>
      <view class="metric-line"><text>总订单金额</text><text>{{summary.totalOrderValueText}}</text></view>
      <view class="metric-line"><text>Operating Margin</text><text>{{summary.operatingMarginText}}</text></view>
    </view>

    <view class="card">
      <view class="section-header">
        <view class="card-title">SAP 绑定信息</view>
        <button class="btn-secondary" size="mini" bindtap="addSap">+ 新增 SAP号</button>
      </view>

      <view wx:for="{{sapBindings}}" wx:for-item="sap" wx:for-index="sapIndex" wx:key="sapId" class="sap-card">
        <view class="row">
          <view class="metric-value">SAP {{sapIndex + 1}} ｜ {{sap.activeText}}</view>
          <view>
            <button wx:if="{{sap.isInactive}}" class="btn-secondary" size="mini" data-index="{{sapIndex}}" bindtap="restoreSap">恢复</button>
            <button wx:if="{{sap.isActive}}" class="btn-danger" size="mini" data-index="{{sapIndex}}" bindtap="removeSap">删除 SAP</button>
          </view>
        </view>

        <label class="form-label">SAP号</label>
        <input class="input" value="{{sap.sapNoText}}" data-index="{{sapIndex}}" data-field="sapOrderNo" bindinput="onSapInput" placeholder="请输入SAP号" />

        <label class="form-label">Item号</label>
        <input class="input" value="{{sap.itemNo}}" data-index="{{sapIndex}}" data-field="itemNo" bindinput="onSapInput" placeholder="7开头SAP默认1000" />

        <label class="form-label">关联人员</label>
        <input class="input" value="{{sap.memberName}}" data-index="{{sapIndex}}" data-field="memberName" bindinput="onSapInput" placeholder="请选择或输入关联人员（选填）" />

        <label class="form-label">备注</label>
        <input class="input" value="{{sap.remark}}" data-index="{{sapIndex}}" data-field="remark" bindinput="onSapInput" placeholder="请输入备注（选填）" />
      </view>
    </view>

    <view class="card">
      <view class="section-header">
        <view class="card-title">Item 信息</view>
        <button class="btn-secondary" size="mini" bindtap="addItem">+ 新增 Item</button>
      </view>

      <view wx:for="{{itemList}}" wx:for-item="it" wx:for-index="itemIndex" wx:key="itemId" class="item-card">
        <view class="row">
          <view class="metric-value">Item {{itemIndex + 1}}</view>
          <button wx:if="{{itemList.length > 1}}" class="btn-danger" size="mini" data-item-index="{{itemIndex}}" bindtap="removeItem">删除 Item</button>
        </view>

        <label class="form-label">Item号</label>
        <input class="input" value="{{it.itemNo}}" data-item-index="{{itemIndex}}" data-field="itemNo" bindinput="onItemInput" />

        <label class="form-label">Item说明</label>
        <input class="input" value="{{it.itemDescription}}" data-item-index="{{itemIndex}}" data-field="itemDescription" bindinput="onItemInput" />

        <label class="form-label">备注</label>
        <input class="input" value="{{it.remark}}" data-item-index="{{itemIndex}}" data-field="remark" bindinput="onItemInput" />
      </view>
    </view>

    <view class="card">
      <label class="form-label">保存原因 / 备注</label>
      <textarea class="textarea" value="{{reason}}" bindinput="onReasonInput" placeholder="例如：首次绑定SAP号 / 修改item号" />
    </view>

    <view class="actions">
      <button class="btn-primary" loading="{{savingSap}}" disabled="{{savingSap}}" bindtap="saveSap">保存 SAP 绑定</button>
    </view>
  </block>
</view>
