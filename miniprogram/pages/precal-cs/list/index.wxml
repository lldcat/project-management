<view class="container">
  <view class="card">
    <view class="card-title">CS - SAP号绑定</view>
    <view class="muted">显示 Submitted / SAP Bound / Project Created 的 Pre-cal；Draft 和 Withdrawn 不显示。</view>
  </view>

  <input class="input search" placeholder="搜索客户 / Sales / SAP号" value="{{keyword}}" bindinput="onSearchInput" />
  <view class="filter-row">
    <view wx:for="{{statusOptions}}" wx:key="value" class="filter {{filterStatus == item.value ? 'active' : ''}}" data-status="{{item.value}}" bindtap="switchStatus">{{item.label}}</view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{records.length == 0}}" class="empty">暂无可处理 Pre-cal</view>
  <view wx:for="{{records}}" wx:key="_id" class="card" bindtap="goBind" data-id="{{item._id}}">
    <view class="row">
      <view>
        <view class="precal-title">{{item.customerNameText}}</view>
        <view class="muted">{{item.service}} ｜ Sales：{{item.salesOwnerNameText}}</view>
      </view>
      <view class="tag {{item.statusTagClass}}">{{item.statusLabel}}</view>
    </view>
    <view class="metric-line"><text>总订单金额</text><text>{{item.totalOrderValueText}}</text></view>
    <view class="metric-line"><text>SAP号</text><text>{{item.sapTextDisplay}}</text></view>
  </view>

  <view wx:if="{{records.length > 0}}" class="empty">
    <button wx:if="{{hasMore}}" class="btn-secondary" loading="{{loadingMore}}" disabled="{{loadingMore}}" bindtap="loadMore">加载更多</button>
    <view wx:else>已加载全部 Pre-cal</view>
  </view>
</view>
