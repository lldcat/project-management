<view class="container">
  <view class="card">
    <view class="card-title">{{pageTitle}}</view>
    <view class="muted">PM/admin 可管理完整项目；项目组员可查看参与项目和自己的分配额度。</view>
  <view wx:if="{{readOnly}}" class="tag tag-warning">只读模式：当前账号可查看该项目，但不能修改预算、成员或 SAP/Pre-cal 信息。</view>
  </view>

  <view class="card">
    <view class="section-title">基础信息</view>
    <label wx:if="{{!isEdit}}" class="form-label">通过 SAP 项目号创建（推荐）</label>
    <input wx:if="{{!isEdit}}" class="input" value="{{sapSearchNo}}" placeholder="输入任一已绑定 SAP 项目号后点击同步" bindinput="onSapInput" />
    <view wx:if="{{!isEdit}}" class="row action-row">
      <button class="btn-secondary" size="mini" loading="{{precalSyncing}}" bindtap="onManualSyncPrecal">同步 Pre-cal 数据</button>
      <text class="muted">{{precalSyncMessage}}</text>
    </view>
    <view wx:if="{{hasPrecalPreview}}" class="sub-card">
      <view class="section-title">已同步 Pre-cal 信息</view>
      <view class="metric-line"><text>Pre-cal 编号</text><text>{{precalDisplay.precalNo}}</text></view>
      <view class="metric-line"><text>Service</text><text>{{precalDisplay.service}}</text></view>
      <view class="metric-line"><text>Sales Owner</text><text>{{precalDisplay.salesOwnerName}}</text></view>
      <view class="metric-line"><text>SAP 项目号</text><text>{{precalDisplay.sapText}}</text></view>
      <view class="metric-line"><text>Pre-cal 项目总预算</text><text>{{precalDisplay.totalBudget}}</text></view>
      <view class="metric-line"><text>可分配工作工时</text><text>{{precalDisplay.budgetHours}}</text></view>
      <view class="metric-line"><text>差旅费</text><text>{{precalDisplay.travelFee}}</text></view>
      <view class="metric-line"><text>Operating Margin</text><text>{{precalDisplay.operatingMargin}}</text></view>
    </view>

    <label class="form-label">项目名称</label>
    <input class="input" disabled="{{readOnly}}" value="{{form.projectName}}" placeholder="例如：某客户 ESG/追溯咨询项目" data-field="projectName" bindinput="onBasicInput" />

    <label class="form-label">客户名称 / 合同主体</label>
    <input class="input" disabled="{{readOnly}}" value="{{form.customerName}}" placeholder="请输入客户名称" data-field="customerName" bindinput="onBasicInput" />

    <label class="form-label">项目号 / 订单号</label>
    <input class="input" disabled="{{readOnly}}" value="{{form.projectNo}}" placeholder="请输入项目号" data-field="projectNo" bindinput="onBasicInput" />

    <view class="grid-2">
      <view>
        <label class="form-label">开始日期</label>
        <picker disabled="{{readOnly}}" mode="date" value="{{form.startDate}}" data-field="startDate" bindchange="onDateChange">
          <view class="picker-value">{{form.startDate || '请选择'}}</view>
        </picker>
      </view>
      <view>
        <label class="form-label">结束日期</label>
        <picker disabled="{{readOnly}}" mode="date" value="{{form.endDate}}" data-field="endDate" bindchange="onDateChange">
          <view class="picker-value">{{form.endDate || '请选择'}}</view>
        </picker>
      </view>
    </view>

    <label class="form-label">项目经理 PM</label>
    <view class="readonly-field">{{pmDisplayName}}</view>
    <view wx:if="{{missingUserName}}" class="muted">PM 使用当前登录用户姓名。请先到“我的”页填写姓名。</view>

    <view wx:if="{{canViewFullProject}}">
      <label class="form-label">项目组员</label>
      <textarea class="textarea" disabled="{{readOnly}}" value="{{memberInputText}}" placeholder="多个组员用逗号、分号、顿号或换行分隔；不需要重复填写 PM" bindinput="onMembersInput" bindblur="addMemberFromInput" bindconfirm="addMemberFromInput" confirm-type="done"></textarea>
      <view wx:if="{{!readOnly}}" class="row member-input-actions">
        <button class="btn-secondary" size="mini" bindtap="addMemberFromInput">添加组员</button>
        <text class="muted">已添加：{{membersText || '暂无'}}</text>
      </view>
      <view class="muted">系统会将确认后的“项目经理 PM + 项目组员”同步到人员预算；AR 人员仅作为实际工时展示。</view>
    </view>

    <label class="form-label">项目状态</label>
    <picker disabled="{{readOnly}}" value="{{statusIndex}}" range="{{statusOptions}}" range-key="label" bindchange="onStatusChange">
      <view class="picker-value">{{currentStatusLabel}}</view>
    </picker>
  </view>

  <view wx:if="{{!canViewFullProject}}" class="card">
    <view class="section-title">我的项目额度</view>
    <view class="metric-line"><text>我的分配额度</text><text class="metric-value">{{myAllocationDisplay.budgetHoursText}}</text></view>
    <view wx:if="{{myAllocationDisplay.hasActualHours}}" class="metric-line"><text>我的已用工时</text><text class="metric-value">{{myAllocationDisplay.actualHoursText}}</text></view>
    <view wx:if="{{myAllocationDisplay.hasBudgetHours}}" class="metric-line"><text>我的剩余额度</text><text class="metric-value">{{myAllocationDisplay.remainingHoursText}}</text></view>
  </view>

  <view wx:if="{{canViewFullProject}}" class="card">
    <view class="section-title">SAP 绑定</view>
    <view wx:if="{{!hasActiveSapBindings}}" class="allocation-warning">当前项目没有有效 SAP 绑定，AR Time 将无法匹配。</view>
    <view wx:for="{{activeSapBindings}}" wx:key="sapId" class="sub-card">
      <view class="sub-title">{{item.sapOrderNo}}</view>
      <view class="metric-line"><text>Item</text><text>{{item.itemNoText}}</text></view>
      <view class="metric-line"><text>关联人员</text><text>{{item.memberNameText}}</text></view>
      <view class="muted">备注：{{item.remarkText}}</view>
    </view>
    <view wx:if="{{hasInactiveSapBindings}}" class="section-title history-title">历史 SAP</view>
    <view wx:for="{{inactiveSapBindings}}" wx:key="sapId" class="sub-card muted-sub-card">
      <view class="sub-title">{{item.sapOrderNo}}（已停用）</view>
      <view class="metric-line"><text>Item</text><text>{{item.itemNoText}}</text></view>
      <view class="muted">原因：{{item.disabledReasonText}} ｜ 备注：{{item.remarkText}}</view>
    </view>
  </view>

  <view wx:if="{{canViewFullProject}}" class="card">
    <view class="row">
      <view class="section-title inline-title">子项目预算与计划</view>
      <button wx:if="{{!readOnly}}" class="btn-secondary" size="mini" bindtap="addSubProject">新增子项目</button>
    </view>

    <view wx:for="{{form.subProjects}}" wx:key="id" class="sub-card">
      <view class="row sub-title-row">
        <view class="sub-title">子项目 {{index + 1}} <text wx:if="{{item.itemNo}}" class="mini-note">Item：{{item.itemNo}}</text></view>
        <button wx:if="{{!readOnly}}" class="btn-danger" size="mini" data-index="{{index}}" bindtap="removeSubProject">删除</button>
      </view>
      <label class="form-label">子项目名称</label>
      <input class="input" disabled="{{readOnly}}" value="{{item.name}}" placeholder="例如：ESG 咨询 / 追溯辅导" data-index="{{index}}" data-field="name" bindinput="onSubProjectInput" />
      <label class="form-label">子项目号 / Item No.</label>
      <input class="input" disabled="{{readOnly}}" value="{{item.itemNo}}" placeholder="例如：1000" data-index="{{index}}" data-field="itemNo" bindinput="onSubProjectInput" />
      <view wx:if="{{item.itemNo}}" class="muted">Item：{{item.itemNo}} {{item.itemDescription}}</view>

      <view class="grid-2">
        <view>
          <label class="form-label">预算工时</label>
          <input class="input" disabled="{{readOnly}}" type="digit" value="{{item.budgetHours}}" placeholder="小时" data-index="{{index}}" data-field="budgetHours" bindinput="onSubProjectInput" />
        </view>
        <view>
          <label class="form-label">子项目差旅费</label>
          <input class="input" disabled="{{readOnly}}" type="digit" value="{{item.travelFee}}" placeholder="元" data-index="{{index}}" data-field="travelFee" bindinput="onSubProjectInput" />
        </view>
      </view>

      <view class="grid-2">
        <view>
          <label class="form-label">报价人天单价</label>
          <input class="input" disabled="{{readOnly}}" type="digit" value="{{item.budgetLaborUnitPrice}}" placeholder="元/人天" data-index="{{index}}" data-field="budgetLaborUnitPrice" bindinput="onSubProjectInput" />
        </view>
      </view>

      <label class="form-label">截至当前复盘节点计划完成工时</label>
      <input class="input" disabled="{{readOnly}}" type="digit" value="{{item.plannedCompletedHours}}" placeholder="小时" data-index="{{index}}" data-field="plannedCompletedHours" bindinput="onSubProjectInput" />
    </view>
  </view>


  <view wx:if="{{canViewAllAllocations}}" class="card">
    <view class="row">
      <view>
        <view class="section-title inline-title">人员预算工时分配</view>
        <view class="muted">用于把可分配工作工时分配到每个员工，并与 AR 工时逐人比较。</view>
      </view>
      <view wx:if="{{!readOnly}}" class="row-actions">
        <button class="btn-secondary" size="mini" bindtap="syncPeopleFromPmAndMembers">同步 PM/组员</button>
        <button class="btn-secondary" size="mini" bindtap="addEmployeeBudget">新增人员</button>
      </view>
    </view>

    <view class="allocation-summary">
      <view class="metric-line"><text>可分配工时</text><text class="metric-value">{{allocationSummary.projectBudgetHoursText}}</text></view>
      <view class="muted">已排除差旅 MD 和报价 MD。</view>
      <view class="metric-line"><text>已分配工时</text><text class="metric-value">{{allocationSummary.allocatedHoursText}}</text></view>
      <view class="metric-line"><text>剩余可分配工时</text><text class="metric-value">{{allocationSummary.remainingHoursText}}</text></view>
      <view class="metric-line"><text>分配比例</text><text class="metric-value">{{allocationSummary.allocationRatioText}}</text></view>
      <view wx:if="{{!allocationSummary.hasProjectBudgetHours}}" class="muted">暂无可分配工时，保存前请确认 Pre-cal 工作人天或项目预算工时。</view>
      <view wx:if="{{allocationSummary.isOverBudget}}" class="allocation-warning">已超出预算工时 {{allocationSummary.overHoursText}} 小时</view>
    </view>

    <view wx:for="{{form.employeeBudgets}}" wx:key="id" class="sub-card">
      <view class="row sub-title-row">
        <view class="sub-title">人员预算 {{index + 1}} <text wx:if="{{item.isPm}}" class="mini-note">PM</text></view>
        <button wx:if="{{item.canRemove}}" class="btn-danger" size="mini" data-index="{{index}}" bindtap="removeEmployeeBudget">删除</button>
      </view>
      <view class="grid-2">
        <view>
          <label class="form-label">员工姓名</label>
          <input class="input" disabled="{{readOnly}}" value="{{item.memberName}}" placeholder="PM 或组员姓名" data-index="{{index}}" data-field="memberName" bindinput="onEmployeeBudgetInput" />
        </view>
        <view>
          <label class="form-label">分配预算工时</label>
          <input class="input" disabled="{{readOnly}}" type="digit" value="{{item.budgetHours}}" placeholder="小时" data-index="{{index}}" data-field="budgetHours" bindinput="onEmployeeBudgetInput" />
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{canViewFullProject}}" class="card">
    <view class="section-title">成本参数</view>
    <label class="form-label">差旅费</label>
    <input class="input" disabled="{{readOnly}}" type="digit" value="{{form.travelFee}}" placeholder="元；纳入 BAC 计算" data-field="travelFee" bindinput="onBasicInput" />

    <label class="form-label">内部人天成本</label>
    <input class="input" disabled="{{readOnly}}" type="digit" value="{{form.constants.personDayCost}}" placeholder="默认 5000，可按后续规则调整" bindinput="onPersonDayCostInput" />
    <view class="muted">AC（实际成本）= AR 工时合计 ÷ 8 × 内部人天成本。</view>
  </view>

  <view wx:if="{{canViewFullProject}}" class="card">
    <view class="section-title">AR Time</view>
    <view class="muted">AR Time 来自 Excel Online，小程序仅展示同步结果，不写回 Excel。</view>
    <view wx:if="{{form.arTimeWarning}}" class="allocation-warning">{{form.arTimeWarning}}</view>
    <view class="metric-line"><text>AR Time 总计</text><text class="metric-value">{{form.arSummary.totalArHours || 0}} h</text></view>
    <view class="metric-line"><text>匹配汇总数</text><text>{{form.arSummary.matchedSummaryCount || 0}}</text></view>
    <view class="metric-line"><text>AR 更新时间</text><text>{{form.arSummary.latestUpdatedAtText || '-'}}</text></view>

    <view wx:if="{{hasArMemberCandidates}}" class="ar-candidate-block">
      <view class="row">
        <view>
          <view class="section-title inline-title">AR Time 发现的人员</view>
          <view class="muted">这些人员仅来自 SAP 匹配结果，不会自动获得项目权限。添加后才会成为项目组员。</view>
        </view>
        <button wx:if="{{!readOnly && canAddArMemberCandidates}}" class="btn-secondary" size="mini" bindtap="addAllArMemberCandidates">添加可匹配人员</button>
      </view>
      <view wx:for="{{arMemberCandidates}}" wx:key="candidateKey" class="sub-card">
        <view class="row sub-title-row">
          <view class="sub-title">{{item.memberName}}</view>
          <view class="tag {{item.statusClass}}">{{item.matchStatusText}}</view>
        </view>
        <view class="metric-line"><text>SAP</text><text>{{item.sapText}}</text></view>
        <view class="metric-line"><text>AR 工时</text><text class="metric-value">{{item.hoursText}} h</text></view>
        <view class="metric-line"><text>匹配汇总数</text><text>{{item.matchedSummaryCountText}}</text></view>
        <view wx:if="{{item.arSheetName && item.arSheetName != item.memberName}}" class="muted">AR 名称：{{item.arSheetName}}</view>
        <button wx:if="{{!readOnly && item.canAdd}}" class="btn-secondary" size="mini" data-index="{{index}}" bindtap="addArMemberCandidate">添加为项目组员</button>
      </view>
    </view>

  </view>

  <view wx:if="{{canViewFullProject}}" class="card">
    <view class="card-title">自动计算预览</view>
    <view class="metric-line"><text>人工预算（不含杂费/差旅）</text><text class="metric-value">{{preview.display.laborBudget}}</text></view>
    <view class="metric-line"><text>杂费 / 差旅费</text><text class="metric-value">{{preview.display.travelFee}}</text></view>
    <view class="metric-line"><text>BAC（系统计算，含杂费/差旅）</text><text class="metric-value">{{preview.display.bac}}</text></view>
    <view class="metric-line"><text>子项目预算工时合计</text><text class="metric-value">{{preview.display.sumBudgetHours}}</text></view>
    <view class="metric-line"><text>人员预算工时合计</text><text class="metric-value">{{preview.display.sumEmployeeBudgetHours}}</text></view>
    <view class="metric-line"><text>人员预算分配差异</text><text class="metric-value">{{preview.display.budgetAllocationDiff}}</text></view>
    <view class="metric-line"><text>计划完成率</text><text class="metric-value">{{preview.display.plannedCompletionRatio}}</text></view>
    <view class="metric-line"><text>PV（计划价值）</text><text class="metric-value">{{preview.display.plannedValue}}</text></view>
    <view class="metric-line"><text>实际完成率</text><text class="metric-value">{{preview.display.actualCompletionRatio}}</text></view>
    <view class="metric-line"><text>EV（挣值）</text><text class="metric-value">{{preview.display.earnedValue}}</text></view>
    <view class="metric-line"><text>AC（实际成本）</text><text class="metric-value">{{preview.display.actualCost}}</text></view>
    <view class="metric-line"><text>CV（成本偏差）</text><text class="metric-value">{{preview.display.costVariance}}</text></view>
    <view class="metric-line"><text>SV（进度偏差）</text><text class="metric-value">{{preview.display.scheduleVariance}}</text></view>
    <view class="metric-line"><text>CPI（成本绩效）</text><text class="metric-value">{{preview.display.cpi}}</text></view>
    <view class="metric-line"><text>SPI（进度绩效）</text><text class="metric-value">{{preview.display.spi}}</text></view>


    <view class="section-title">人员预算 vs AR 明细</view>
    <view wx:if="{{preview.display.memberBudgetComparisons.length == 0}}" class="muted">暂无人员预算或 AR 明细。</view>
    <view wx:for="{{preview.display.memberBudgetComparisons}}" wx:key="memberName" class="sub-card">
      <view class="row">
        <view class="sub-title">{{item.memberName}}</view>
        <view class="tag {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="metric-line"><text>分配预算工时</text><text class="metric-value">{{item.budgetHours}}</text></view>
      <view class="metric-line"><text>AR 工时</text><text class="metric-value">{{item.actualHours}}</text></view>
      <view class="metric-line"><text>剩余/超出工时</text><text class="metric-value">{{item.varianceHours}}</text></view>
      <view class="metric-line"><text>个人预算使用率</text><text class="metric-value">{{item.usageRatio}}</text></view>
    </view>

    <view class="section-title">异常提醒</view>
    <view wx:for="{{preview.metrics.alerts}}" wx:key="code" class="tag {{item.statusClass}}">
      {{item.text}}
    </view>
  </view>

  <view class="bottom-bar">
    <button class="btn-ghost" bindtap="goBack">返回</button>
    <button wx:if="{{!readOnly}}" class="btn-primary" bindtap="saveProject">保存项目</button>
  </view>
</view>
