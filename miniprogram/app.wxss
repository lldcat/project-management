page {
  background: #f5f7fb;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin: 24rpx 0 16rpx;
}

.muted {
  color: #667085;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx;
  box-shadow: 0 6rpx 18rpx rgba(16, 24, 40, 0.05);
}

.stat-value {
  font-size: 42rpx;
  font-weight: 800;
  color: #1f4e79;
}

.stat-label {
  font-size: 24rpx;
  color: #667085;
}

.input, .textarea, .picker-value {
  min-height: 80rpx;
  padding: 0 20rpx;
  background: #f9fafb;
  border: 1rpx solid #d0d5dd;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 150rpx;
  padding-top: 18rpx;
}

.form-label {
  display: block;
  margin: 18rpx 0 8rpx;
  font-size: 25rpx;
  color: #344054;
  font-weight: 600;
}

.btn-primary, .btn-secondary, .btn-danger, .btn-ghost {
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 4rpx 18rpx;
  margin: 0;
}

.btn-primary {
  background: #1f4e79;
  color: #ffffff;
}

.btn-secondary {
  background: #e9f2fb;
  color: #1f4e79;
}

.btn-danger {
  background: #fee4e2;
  color: #b42318;
}

.btn-ghost {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.tag-normal {
  color: #027a48;
  background: #d1fadf;
}

.tag-risk {
  color: #b42318;
  background: #fee4e2;
}

.tag-warning {
  color: #b54708;
  background: #fef0c7;
}

.metric-line {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f2f4f7;
  font-size: 25rpx;
}

.metric-line:last-child {
  border-bottom: none;
}

.metric-value {
  font-weight: 700;
}

.empty {
  padding: 60rpx 20rpx;
  text-align: center;
  color: #98a2b3;
}
