.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.06);
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #101828;
}

.muted {
  color: #667085;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-normal {
  background: #e8f3ff;
  color: #1f4e79;
}

.tag-disabled {
  background: #f2f4f7;
  color: #667085;
}

.status-column {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.role-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 24rpx 0;
}

.role-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #344054;
}

.btn-primary {
  background: #1f4e79;
  color: #fff;
}

.empty {
  padding: 48rpx;
  color: #667085;
  text-align: center;
}
