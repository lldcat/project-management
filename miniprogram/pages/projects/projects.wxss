.search {
  margin-top: 18rpx;
}
.filter-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}
.export-panel {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e4e7ec;
}
.pm-filter-box {
  padding: 16rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #fff;
}
.pm-checkbox {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 56rpx;
  margin-right: 18rpx;
  color: #344054;
  font-size: 26rpx;
}
.project-title {
  font-size: 32rpx;
  font-weight: 800;
}
.project-card {
  overflow: hidden;
}
.small-metrics {
  margin-top: 14rpx;
  color: #344054;
  font-size: 24rpx;
}
.alert-list {
  margin-top: 14rpx;
}
.action-row {
  margin-top: 18rpx;
  justify-content: flex-end;
}
