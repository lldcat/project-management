# Azure AD tenant id, for example: 00000000-0000-0000-0000-000000000000
MS_TENANT_ID=

# Azure App Registration application/client id
MS_CLIENT_ID=

# Azure App Registration client secret. Never commit a real value.
MS_CLIENT_SECRET=

# Microsoft Graph drive id for the OneDrive for Business document library
MS_DRIVE_ID=

# Microsoft Graph item id for the target Excel workbook
MS_ITEM_ID=

# Employee worksheet to read, for example: Zhang Bailiang
MS_WORKSHEET_NAME=Zhang Bailiang
