.business-page {
  padding-bottom: 40rpx;
}

.hero-card {
  background: linear-gradient(135deg, #1f4e79 0%, #2f6fa3 100%);
  color: #ffffff;
}

.hero-card .muted {
  color: rgba(255, 255, 255, 0.78);
}

.hero-kicker {
  font-size: 24rpx;
  opacity: 0.86;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.section-block {
  margin-top: 10rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  min-height: 150rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.06);
  border: 1rpx solid #eef2f6;
}

.primary-action {
  border-color: #bfdbfe;
  background: #eff8ff;
}

.action-title {
  color: #1f4e79;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.action-desc {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.empty-card {
  margin-top: 24rpx;
}
