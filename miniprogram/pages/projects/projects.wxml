<view class="container">
  <view class="card">
    <view class="row">
      <view>
        <view class="card-title">{{listTitle}}</view>
        <view class="muted">{{scopeText}}</view>
        <view class="muted">用于查看、筛选和复核项目。创建项目请进入“业务”页。</view>
      </view>
    </view>
    <input class="input search" placeholder="搜索项目名称、项目号、客户或 PM" value="{{keyword}}" bindinput="onSearchInput" />
    <view class="filter-row">
      <button class="{{filter == 'all' ? 'btn-primary' : 'btn-ghost'}}" size="mini" data-filter="all" bindtap="switchFilter">全部</button>
      <button class="{{filter == 'risk' ? 'btn-primary' : 'btn-ghost'}}" size="mini" data-filter="risk" bindtap="switchFilter">风险</button>
      <button class="{{filter == 'normal' ? 'btn-primary' : 'btn-ghost'}}" size="mini" data-filter="normal" bindtap="switchFilter">正常</button>
      <button wx:if="{{canExport}}" class="btn-secondary" size="mini" loading="{{exporting}}" disabled="{{exporting}}" bindtap="toggleExportPanel">项目导出</button>
    </view>
    <view wx:if="{{exportPanelVisible}}" class="export-panel">
      <view class="section-title">模板化导出</view>
      <label class="form-label">项目状态</label>
      <picker value="{{exportStatusIndex}}" range="{{exportStatusOptions}}" range-key="label" bindchange="onExportStatusChange">
        <view class="picker-value">{{exportStatusOptions[exportStatusIndex].label}}</view>
      </picker>

      <label class="form-label">PM 筛选</label>
      <view class="pm-filter-box">
        <view class="muted">{{selectedPmText}}</view>
        <view wx:if="{{exportPmOptionsText}}" class="muted">{{exportPmOptionsText}}</view>
        <checkbox-group bindchange="onPmCheckboxChange">
          <label wx:for="{{exportPmOptions}}" wx:key="name" class="pm-checkbox">
            <checkbox value="{{item.name}}" checked="{{item.checked}}" />
            <text>{{item.name}}</text>
          </label>
        </checkbox-group>
      </view>

      <view class="grid-2">
        <view>
          <label class="form-label">客户名称</label>
          <input class="input" value="{{exportFilters.customerName}}" data-field="customerName" placeholder="可留空" bindinput="onExportFilterInput" />
        </view>
        <view>
          <label class="form-label">项目名称</label>
          <input class="input" value="{{exportFilters.projectName}}" data-field="projectName" placeholder="可留空" bindinput="onExportFilterInput" />
        </view>
      </view>

      <label class="form-label">SAP 号</label>
      <input class="input" value="{{exportFilters.sapNo}}" data-field="sapNo" placeholder="可输入完整或部分 SAP 号" bindinput="onExportFilterInput" />

      <view class="grid-2">
        <view>
          <label class="form-label">创建开始</label>
          <picker mode="date" value="{{exportFilters.createdStart}}" data-field="createdStart" bindchange="onExportDateChange">
            <view class="picker-value">{{exportFilters.createdStart || '不限'}}</view>
          </picker>
        </view>
        <view>
          <label class="form-label">创建结束</label>
          <picker mode="date" value="{{exportFilters.createdEnd}}" data-field="createdEnd" bindchange="onExportDateChange">
            <view class="picker-value">{{exportFilters.createdEnd || '不限'}}</view>
          </picker>
        </view>
      </view>

      <view class="grid-2">
        <view>
          <label class="form-label">完结开始</label>
          <picker mode="date" value="{{exportFilters.closedStart}}" data-field="closedStart" bindchange="onExportDateChange">
            <view class="picker-value">{{exportFilters.closedStart || '不限'}}</view>
          </picker>
        </view>
        <view>
          <label class="form-label">完结结束</label>
          <picker mode="date" value="{{exportFilters.closedEnd}}" data-field="closedEnd" bindchange="onExportDateChange">
            <view class="picker-value">{{exportFilters.closedEnd || '不限'}}</view>
          </picker>
        </view>
      </view>

      <view class="row action-row">
        <button class="btn-secondary" size="mini" bindtap="resetExportFilters">重置</button>
        <button class="btn-primary" size="mini" loading="{{exporting}}" disabled="{{exporting}}" bindtap="exportTemplate">按模板导出</button>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{filteredProjects.length == 0}}" class="empty">暂无项目。需要创建项目时，请进入底部“业务”页。</view>

  <view wx:for="{{filteredProjects}}" wx:key="_id" class="card project-card">
    <view bindtap="editProject" data-id="{{item._id}}">
      <view class="row">
        <view>
          <view class="project-title">{{item.projectNameText}}</view>
          <view class="muted">{{item.projectNoText}} ｜ {{item.customerNameText}} ｜ PM：{{item.displayPmName}}</view>
        </view>
        <view class="tag {{item.riskTagClass}}">{{item.riskTagText}}</view>
      </view>
      <view wx:if="{{item._canViewFullProject}}">
        <view class="metric-line">
          <text>BAC（系统计算，含杂费/差旅）</text>
          <text class="metric-value">{{item.display.bac}}</text>
        </view>
        <view class="metric-line">
          <text>人工预算（不含杂费/差旅）</text>
          <text class="metric-value">{{item.display.laborBudget}}</text>
        </view>
        <view class="metric-line">
          <text>人员预算工时合计</text>
          <text class="metric-value">{{item.display.sumEmployeeBudgetHours}}</text>
        </view>
      </view>
      <view wx:if="{{item.showMyAllocation}}" class="metric-line">
        <text>我的分配额度</text>
        <text class="metric-value">{{item.myAllocationText}}</text>
      </view>
      <view wx:if="{{item._canViewFullProject}}">
        <view class="metric-line">
          <text>AC（实际成本）</text>
          <text class="metric-value">{{item.display.actualCost}}</text>
        </view>
        <view class="grid-2 small-metrics">
          <view>实际完成：<text class="metric-value">{{item.display.actualCompletionRatio}}</text></view>
          <view>计划完成：<text class="metric-value">{{item.display.plannedCompletionRatio}}</text></view>
        </view>
        <view class="alert-list">
          <view wx:for="{{item.metrics.alerts}}" wx:for-item="alert" wx:key="code" class="tag {{alert.statusClass}}">
            {{alert.text}}
          </view>
        </view>
      </view>
    </view>
    <view class="row action-row">
      <button class="btn-secondary" size="mini" bindtap="editProject" data-id="{{item._id}}">{{item._canEdit ? '编辑' : '查看'}}</button>
      <button wx:if="{{item._canEdit}}" class="btn-danger" size="mini" loading="{{deletingId == item._id}}" disabled="{{deletingId != ''}}" bindtap="deleteProject" data-id="{{item._id}}">删除</button>
    </view>
  </view>

  <view wx:if="{{filteredProjects.length > 0}}" class="empty">
    <button wx:if="{{hasMore}}" class="btn-secondary" loading="{{loadingMore}}" disabled="{{loadingMore}}" bindtap="loadMore">加载更多</button>
    <view wx:else>已加载全部项目</view>
  </view>
</view>
