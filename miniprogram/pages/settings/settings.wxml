<view class="container">
  <view class="card profile-card">
    <view class="card-title">我的</view>
    <view class="muted">维护基础资料和当前账号状态。</view>
    <view wx:if="{{missingName}}" class="tag tag-warning">首次使用请填写姓名，项目 PM 和分配工时会使用该姓名。</view>

    <label class="form-label">姓名</label>
    <input class="input" value="{{nameInput}}" placeholder="请输入姓名，建议与 AR 表一致" bindinput="onNameInput" confirm-type="done" bindconfirm="saveName" />
    <button class="btn-primary name-save" loading="{{savingName}}" bindtap="saveName">保存姓名</button>

    <view class="metric-line">
      <text>当前姓名</text>
      <text class="metric-value">{{name || '-'}}</text>
    </view>
    <view class="metric-line">
      <text>登录状态</text>
      <text class="metric-value">{{loginStatusText}}</text>
    </view>
    <view class="metric-line">
      <text>账号状态</text>
      <text class="metric-value">{{accountStatusText}}</text>
    </view>

    <button class="btn-secondary refresh" bindtap="refreshLogin">刷新登录状态</button>
  </view>

  <view wx:if="{{canSwitchRoleView}}" class="card profile-card">
    <view class="card-title">Admin 测试视角</view>
    <view class="muted">临时切换小程序视角，用于检查 PM、Sales、CS、AR 或组员看到的入口和数据范围。</view>
    <picker mode="selector" range="{{roleViewOptions}}" range-key="label" value="{{roleViewIndex}}" bindchange="onRoleViewChange">
      <view class="input role-view-picker">
        <text>{{roleViewText}}</text>
        <text class="muted">点击切换</text>
      </view>
    </picker>
    <view class="muted role-view-note">该选项只影响当前 admin 的测试视角，不会修改数据库中的用户权限。</view>
  </view>
</view>
